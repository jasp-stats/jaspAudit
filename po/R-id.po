msgstr "Evaluasi dari Objektif Pensampelan"

msgid "An error occurred while creating this plot: The results contain NAs"
msgstr "Terjadi galat ketika membuat diagram ini: Hasil berisi NA"

msgid "Upper bound"
msgstr "Batas atas"

