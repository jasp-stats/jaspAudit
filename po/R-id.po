msgstr ""
"Hipotesis null menentukan bahwa tingkat positif palsu dari grup tidak berhak "
"lebih rendah dari, atau sama dengan, yang grup berhak (P)."

msgid "<b>Table %1$i.</b> Model Performance"
msgstr "<b>Tabel %1$i.</b> Kinerja Model"

